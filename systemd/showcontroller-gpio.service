[Unit]
Description=ShowController GPIO Engine
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=raspberry
WorkingDirectory=/opt/showcontroller
ExecStart=/usr/bin/python3 /opt/showcontroller/service.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
