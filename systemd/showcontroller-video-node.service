[Unit]
Description=ShowController Video Node
After=multi-user.target

[Service]
ExecStart=/usr/bin/python3 /opt/showcontroller/modules/video_player/node.py
WorkingDirectory=/opt/showcontroller
Restart=always
RestartSec=3
User=raspberry
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
